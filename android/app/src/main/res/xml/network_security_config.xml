<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Bundle GeoTrust TLS RSA CA G1 intermediate cert — nepalstock.com server omits it,
         causing chain validation failure in release builds. Chrome auto-fetches it; WebView doesn't. -->
    <domain-config>
        <domain includeSubdomains="true">nepalstock.com</domain>
        <domain includeSubdomains="true">nepalstock.com.np</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="@raw/nepse_root_ca" />
        </trust-anchors>
    </domain-config>
</network-security-config>
